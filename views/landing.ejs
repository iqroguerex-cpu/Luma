<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome - Your Personal AI Therapist</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&display=swap" rel="stylesheet">

    <style>
        /*
        ========================================
        CSS Reset and Basic Setup
        ========================================
        */
        :root {
            /* Color Palette */
            --primary-text-color: #FFFFFF;
            --button-bg-color: rgba(255, 255, 255, 0.15);
            --button-hover-bg: rgba(255, 255, 255, 0.25);
            --button-border-color: rgba(255, 255, 255, 0.5);
            --overlay-color: rgba(10, 5, 20, 0.5); /* A deep, calming overlay */

            /* Typography & Spacing */
            --main-font: 'Nunito', sans-serif;
            --base-font-size: 16px;
            --global-transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); /* A smoother transition */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            font-size: var(--base-font-size);
        }

        body {
            font-family: var(--main-font);
            color: var(--primary-text-color);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /*
        ========================================
        Full-Screen Video Background (FIXED FOR CLARITY AND CROPPING)
        ========================================
        */
        .video-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -200; /* Made it even lower just to be absolutely sure */
            
            /* --- FIXES START HERE --- */

            /* Ensure video covers the entire viewport */
            object-fit: cover; 
            
            /* REMOVED: filter: blur(3px); -- this was causing the blur! */
            
            /* Fallback background color in case video doesn't load or covers fully */
            background-color: #000; 

            /* Prevent any potential white lines if video aspect ratio is very off */
            font-family: 'object-fit: cover;'; /* A little hack for older browsers */

            /* --- FIXES END HERE --- */
        }

        /*
        ========================================
        Dark Overlay (Z-index adjustment)
        ========================================
        */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: var(--overlay-color);
            z-index: -100; /* Placed above the video, below content */
        }

        /*
        ========================================
        Main Content Container
        ========================================
        */
        .content-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
            padding: 2rem;
            position: relative; /* Ensures it's above the overlay */
            z-index: 1;         /* Ensures it's above the overlay */
        }

        /*
        ========================================
        Typography and Text Styling
        ========================================
        */
        .main-heading {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: 1px;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            
            opacity: 0;
            transform: translateY(30px);
            animation: fadeIn 1s forwards cubic-bezier(0.25, 0.8, 0.25, 1);
            animation-delay: 0.2s;
        }

        .sub-heading {
            font-size: 1.25rem;
            font-weight: 400;
            max-width: 600px;
            margin-bottom: 2.5rem;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);

            opacity: 0;
            transform: translateY(30px);
            animation: fadeIn 1s forwards cubic-bezier(0.25, 0.8, 0.25, 1);
            animation-delay: 0.5s;
        }

        /*
        ========================================
        The "Begin Session" Button Styling
        ========================================
        */
        .cta-button {
            display: inline-block;
            text-decoration: none;
            color: var(--primary-text-color);
            font-size: 1.1rem;
            font-weight: 700;
            padding: 1rem 3rem;
            
            background: var(--button-bg-color);
            border: 1px solid var(--button-border-color);
            border-radius: 50px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            
            cursor: pointer;
            transition: var(--global-transition);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);

            opacity: 0;
            transform: translateY(30px);
            animation: fadeIn 1s forwards cubic-bezier(0.25, 0.8, 0.25, 1);
            animation-delay: 0.8s;
        }

        .cta-button:hover {
            background: var(--button-hover-bg);
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.25);
        }

        .cta-button:active {
            transform: translateY(-2px) scale(1.02);
        }
        
        /* Keyframe animation for the fade-in effect */
        @keyframes fadeIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /*
        ========================================
        Responsiveness
        ========================================
        */

        /* For Tablets */
        @media (max-width: 768px) {
            .main-heading {
                font-size: 2.8rem;
            }

            .sub-heading {
                font-size: 1.1rem;
            }

            .cta-button {
                padding: 0.9rem 2.5rem;
                font-size: 1rem;
            }
        }
        
        /* For Mobile Phones */
        @media (max-width: 480px) {
            .main-heading {
                font-size: 2.2rem;
            }

            .sub-heading {
                font-size: 1rem;
                margin-bottom: 2rem;
            }

            .cta-button {
                width: 90%;
                padding: 1rem 2rem;
            }
        }

    </style>
</head>
<body>

    <video playsinline autoplay muted loop class="video-background">
        <source src="/videos/loading.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>

    <div class="overlay"></div>

    <div class="content-container">
        <h1 class="main-heading">A Safe Space to Talk</h1>
        <p class="sub-heading">
            Your personal AI companion is here to listen without judgment.
            Whenever you're ready, just begin.
        </p>
        
        <a href="/chat" class="cta-button">Begin Session</a>
    </div>

</body>
</html>